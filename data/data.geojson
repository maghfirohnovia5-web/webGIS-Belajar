{
  "type": "FeatureCollection",
  "features": []
}
<script>
  var map = L.map('map').setView([-7.2, 110.4], 10);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap'
  }).addTo(map);

  fetch('data/data.geojson')
    .then(res => res.json())
    .then(data => {
      L.geoJSON(data).addTo(map);
    });
</script>
